PORT=3000
HOST=127.0.0.1

# Optional. Use this if Duolingo hides some data for your profile.
# Paste only your JWT token value, not "Bearer ...".
DUOLINGO_JWT=

# Optional. If set, clients must send: X-API-Key: your-secret
API_KEY=

# Cache Duolingo responses briefly to avoid hitting their service too often.
CACHE_TTL_SECONDS=60
REQUEST_TIMEOUT_MS=15000
CORS_ORIGIN=*
